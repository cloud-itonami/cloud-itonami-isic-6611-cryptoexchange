{:paths ["src"]
 ;; langgraph-clj powers the cryptoexchange.actor StateGraph (M4) and
 ;; brings langchain-clj transitively — langchain.db is the Datomic-API-
 ;; compatible EAV store behind cryptoexchange.store's DatomicStore (M2d,
 ;; the kotoba-datomic seam). Same layering as the sibling wave-0 finance
 ;; actors (e.g. cloud-itonami-isic-6511). These :local/root paths only
 ;; resolve inside the monorepo checkout; a standalone fork should
 ;; override them with git coordinates.
 :deps {io.github.com-junkawasaki/langgraph-clj
        {:local/root "../../kotoba-lang/langgraph"}
        ;; merkle-sum: the shared Merkle-sum tree behind PoR/PoL
        ;; (cryptoexchange.attest), extracted to kotoba-lang so any actor
        ;; needing proof-of-reserves reuses one audited implementation.
        io.github.kotoba-lang/merkle-sum
        {:local/root "../../kotoba-lang/merkle-sum"}
        ;; langchain-store: the shared langchain.db store seam (EDN-blob
        ;; codec + identity schema + event-log helpers) that ~190 actors
        ;; hand-roll; cryptoexchange.store is the reference adopter
        ;; (ADR-2607141600).
        io.github.kotoba-lang/langchain-store
        {:local/root "../../kotoba-lang/langchain-store"}
        ;; btc-crypto: Bitcoin address encoders (bech32/base58) reused by
        ;; the REAL WYSIWYS BTC decoder (cryptoexchange.wysiwys-btc). JVM-
        ;; only (byte-array/System) — a deliberate compat layer at the
        ;; JVM actuation boundary (the actor's broadcast path is JVM), NOT
        ;; on the portable CLJS kernel path.
        io.github.kotoba-lang/btc-crypto
        {:local/root "../../kotoba-lang/btc-crypto"}
        ;; eth-crypto: Ethereum RLP-encode + EIP-55 checksum reused by the
        ;; REAL WYSIWYS ETH decoder (cryptoexchange.wysiwys-eth). Same
        ;; JVM-only actuation-boundary compat layer as wysiwys-btc.
        io.github.kotoba-lang/eth-crypto
        {:local/root "../../kotoba-lang/eth-crypto"}}
 :aliases
 {;; offline workspace dev — pin transitive langchain to the local checkout.
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; PRIMARY gate: the same portable .cljc suite under a real
  ;; ClojureScript host (runtime priority: cljs first, JVM compat).
  ;;   clojure -Sdeps '{:paths ["src" "test"]}' -M:dev:cljs \
  ;;     -m cljs.main --target node -m cryptoexchange.portable-cljs-test-runner
  :cljs {:extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
